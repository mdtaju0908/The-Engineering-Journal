{
  "name": "md-taju-blogger",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone blog frontend and backend for The Engineering Journal.",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch index.ts",
    "build": "tsc",
    "check": "tsc --noEmit",
    "agent:once": "tsx scripts/runAgentOnce.ts",
    "ssg": "tsx scripts/ssg.ts"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@payloadcms/db-mongodb": "^3.0.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "fast-xml-parser": "^5.8.0",
    "firebase-admin": "^14.1.0",
    "google-trends-api": "^4.9.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^12.0.2",
    "mongoose": "^8.23.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.5.0",
    "payload": "^3.0.0",
    "redis": "^5.10.0",
    "sharp": "^0.33.5",
    "slugify": "^1.6.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "ws": "^8.19.0"
  },
  "overrides": {
    "multer-storage-cloudinary": {
      "cloudinary": "$cloudinary"
    }
  },
  "devDependencies": {
    "@types/node": "^20.19.0"
  }
}
